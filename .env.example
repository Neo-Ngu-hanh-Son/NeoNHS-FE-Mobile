# ── API (EXPO_PUBLIC_* is inlined when Metro bundles / when EAS builds) ─────────
#
# Deployed backend (typical for physical device + production):
#   Use your public HTTPS base, including /api if your server mounts routes there.
#   Example: EXPO_PUBLIC_API_URL=https://api.yourdomain.com/api
#   The device must trust the TLS certificate (no self-signed unless you pin it).
#
# EAS Build: set the same variable for the profile you use, e.g. in eas.json:
#   "build": { "preview": { "env": { "EXPO_PUBLIC_API_URL": "https://..." } } }
#   or: eas env:create --name EXPO_PUBLIC_API_URL --value "https://..." --scope project
#
# Local dev on a physical phone (same Wi-Fi as PC): LAN IP, not localhost.
#   EXPO_PUBLIC_API_URL=http://192.168.1.42:8080/api
#
# Android emulator only (host machine): EXPO_PUBLIC_API_URL=http://10.0.2.2:8080/api
#
EXPO_PUBLIC_API_URL=https://api.example.com/api

EXPO_PUBLIC_FE_URL=https://app.example.com

EXPO_PUBLIC_ENV=development

EXPO_PUBLIC_GOOGLE_MAP_API=somerandomkey

EXPO_PUBLIC_VIET_MAP_API=somerandomkey
