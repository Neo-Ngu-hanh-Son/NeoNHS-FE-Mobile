{
  "name": "neonhs",
  "main": "index.tsx",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start",
    "dev": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "clean": "rm -rf .expo node_modules",
    "test": "jest --watchAll",
    "typecheck": "tsc --noEmit",
    "start:prod": "cross-env NODE_ENV=production expo start --no-dev --minify",
    "start:dev": "cross-env NODE_ENV=development expo start --dev-client",
    "start:staging": "cross-env NODE_ENV=staging expo start --dev-client",
    "lint": "expo lint"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/jest.env.mocks.ts"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(?:.pnpm/)?((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|@rn-primitives))"
    ],
    "moduleNameMapper": {
      "\\.(png|jpg|jpeg|gif|webp|svg)$": "<rootDir>/__mocks__/fileMock.js"
    }
  },
